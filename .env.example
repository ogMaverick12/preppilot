# PrepPilot — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Telegram Bot (optional; off for the local event build) ─────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Optional Hosted LLM Provider ────────────────────────────────────────────────
# PrepPilot's Hermes layer works without this key by using local heuristic mode.
# Add an OpenRouter key only if you want optional external LLM-powered reviews.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nousresearch/hermes-3-llama-3.1-70b

# ─── Local WSL Hermes CLI ────────────────────────────────────────────────────────
HERMES_WSL_DISTRO=Ubuntu
HERMES_WSL_COMMAND=/home/sreej/.local/bin/hermes

# ─── Database ────────────────────────────────────────────────────────────────────
# SQLite for the local event build.
DATABASE_URL=sqlite+aiosqlite:///data/prep_pilot.db

# ─── URLs ────────────────────────────────────────────────────────────────────────
APP_MODE=local
NEXT_PUBLIC_APP_MODE=local

# Backend API URL
BACKEND_URL=http://localhost:8000

# Dashboard URL
DASHBOARD_URL=http://localhost:3000

# Frontend API URL (used by Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── NextAuth (local profile sessions) ───────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000
